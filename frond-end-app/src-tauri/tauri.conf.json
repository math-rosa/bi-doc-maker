{
  "$schema": "https://tauri.app/v1/api/config",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "BI Doc Maker",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true
      }
    },
    "windows": [
      {
        "title": "BI Doc Maker",
        "width": 960,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "identifier": "com.mathrosa.bidocmaker",
      "icon": [
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/documentador-core"
      ]
    }
  }
}
